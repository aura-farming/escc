{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ESCC install-profiles manifest",
  "description": "manifests/install-profiles.json — persona bundles (sdr, ae, sales-manager, revops, full) that expand to a set of install modules.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "profiles"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "profiles": {
      "type": "object",
      "description": "map of profile id -> profile definition",
      "additionalProperties": { "$ref": "#/definitions/profile" }
    }
  },
  "definitions": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules"],
      "properties": {
        "description": { "type": "string" },
        "modules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
