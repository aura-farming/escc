{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aura-farming/escc/schemas/instinct.schema.json",
  "title": "ESCC Instinct",
  "description": "A learned sales instinct (A.3). confidence nominal range is 0.3-0.9; 0..1 is allowed so the I4 decay sweep can move a value below 0.3 toward retirement without failing validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "trigger", "confidence", "domain", "scope", "created"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "trigger": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "domain": {
      "type": "string",
      "enum": ["outreach", "deals", "process", "crm", "preferences"]
    },
    "scope": { "type": "string", "enum": ["personal", "team"] },
    "source": { "type": ["string", "null"] },
    "applies_to": {
      "description": "Comma-separated segment list (e.g. 'enterprise,mid-market'), or empty/'all' for a global instinct (C6).",
      "type": ["string", "null"]
    },
    "workspace_id": { "type": ["string", "null"] },
    "workspace_name": { "type": ["string", "null"] },
    "created": { "type": "string", "minLength": 1 },
    "last_observed": { "type": ["string", "null"] },
    "decay_exempt": { "type": ["boolean", "null"] },
    "action": { "type": ["string", "null"] },
    "evidence": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    }
  }
}
