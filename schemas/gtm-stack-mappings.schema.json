{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ESCC GTM stack mappings",
  "description": "config/gtm-stack-mappings.json — maps detected GTM-stack indicators (available MCP tool-name globs) to recommended ESCC skills/rules/hooks/profile. Consumed by team-init to tailor a workspace to the connected stack.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mappings"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "mappings": {
      "type": "array",
      "items": { "$ref": "#/definitions/mapping" }
    }
  },
  "definitions": {
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["indicator", "recommends"],
      "properties": {
        "indicator": {
          "type": "string",
          "minLength": 1,
          "description": "an available MCP tool-name glob, e.g. mcp__hubspot__* — presence triggers the recommendation"
        },
        "label": {
          "type": "string",
          "description": "human-readable stack label, e.g. HubSpot CRM"
        },
        "recommends": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "skills": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "hooks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "profile": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
