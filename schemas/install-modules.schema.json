{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ESCC install-modules manifest",
  "description": "manifests/install-modules.json — the installable module catalog read by scripts/lib/install-manifests.js. Each module names source paths, supported targets, and its dependency closure.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "modules"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/definitions/module" }
    }
  },
  "definitions": {
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "paths", "targets"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "minLength": 1,
          "description": "module family, e.g. rules | skills | agents | commands | hooks | instincts | statusline | mcp | docs"
        },
        "description": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["claude", "claude-project"] }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "defaultInstall": { "type": "boolean" },
        "cost": {
          "type": "string",
          "minLength": 1,
          "description": "install weight, e.g. light | medium | heavy"
        },
        "stability": {
          "type": "string",
          "minLength": 1,
          "description": "maturity, e.g. stable | beta | experimental"
        },
        "synthetic": {
          "type": "boolean",
          "description": "true for modules generated at load time (e.g. per-skill install surfaces)"
        }
      }
    }
  }
}
