# ESCC environment-variable surface (ESCC_*)
# Copy to .env; never commit real values. MCP API keys/tokens are configured in mcp-configs/, not here.
#
# All variables are optional: every one falls back to the default shown.
# ECC_* names/defaults are mirrored verbatim as ESCC_*. Booleans accept on/off
# and 1/0 (true/false) unless noted. Durations accept suffixes like 30s, 5m, 1h.

# ─────────────────────────────────────────────────────────────────────────────
# Hook dispatch & profile gating
# ─────────────────────────────────────────────────────────────────────────────

# Hook profile: which tier of hooks runs. Allowed: minimal | standard | strict.
ESCC_HOOK_PROFILE=standard

# Comma-separated hook ids to force-off regardless of profile.
# Ids use the pre:/post:/stop:/session: grammar.
# Example: pre:crm-write-guard,post:deliverables-location
ESCC_DISABLED_HOOKS=

# Max bytes of hook stdin to read before truncating. Oversized input fails OPEN
# (the action proceeds) and is recorded as hook_input_truncated when governance
# capture is enabled. Integer bytes.
ESCC_HOOK_INPUT_MAX_BYTES=1048576

# ─────────────────────────────────────────────────────────────────────────────
# Session persistence & SessionStart context injection
# ─────────────────────────────────────────────────────────────────────────────

# Char budget for the SessionStart context block (prior summary + open loops +
# high-confidence instincts), priority-budgeted by category. Integer chars.
ESCC_SESSION_START_MAX_CHARS=8000

# Toggle SessionStart context injection entirely. Allowed: on | off.
ESCC_SESSION_START_CONTEXT=on

# Retention for session-data/ summaries, in days. 0 or off = keep all.
ESCC_SESSION_RETENTION_DAYS=30

# Data root for all ESCC state (session-data/, escc/state/, instincts, etc.).
# Path; ~ is expanded.
ESCC_AGENT_DATA_HOME=~/.claude

# ─────────────────────────────────────────────────────────────────────────────
# Observability, metrics & governance
# ─────────────────────────────────────────────────────────────────────────────

# Emit context-utilization / cost warnings from the context-monitor hook.
# Allowed: on | off.
ESCC_CONTEXT_MONITOR_COST_WARNINGS=on

# Capture audit events (secret_detected, policy_violation, approval_requested,
# hook_input_truncated, bulk_send_attempt, unapproved_send, crm_destructive_op).
# Off by default; set 1/on to enable. Allowed: on | off.
ESCC_GOVERNANCE_CAPTURE=off

# Timeout for async observe hooks (observe-runner). Blank = built-in default.
# Duration in ms, or with a suffix (e.g. 5000, 5s).
ESCC_OBSERVE_TIMEOUT_MS=

# ─────────────────────────────────────────────────────────────────────────────
# MCP health & connectivity
# ─────────────────────────────────────────────────────────────────────────────

# If true, the mcp-health-check hook fails OPEN on a degraded/unreachable MCP
# (action proceeds). Default false = block on unhealthy MCP. Allowed: true | false.
ESCC_MCP_HEALTH_FAIL_OPEN=false

# Path to the MCP health state file used by mcp-health-check. Blank = default
# under ESCC_AGENT_DATA_HOME. Path.
ESCC_MCP_HEALTH_STATE_PATH=

# Path to the MCP servers config (the mcp-configs/ servers file). Blank = default.
# Path.
ESCC_MCP_CONFIG_PATH=

# Command run to attempt an MCP reconnect when a server is unhealthy.
# Blank = no auto-reconnect. Shell command string.
ESCC_MCP_RECONNECT_COMMAND=

# Comma-separated MCP server names to skip (health checks and routing).
# Example: fireflies,hubspot
ESCC_DISABLED_MCPS=

# ─────────────────────────────────────────────────────────────────────────────
# Outbound send gate & quality gates
# ─────────────────────────────────────────────────────────────────────────────

# Strict mode for warn-only quality hooks (outbound-style-check, etc.):
# escalates warnings toward blocking. Allowed: true | false.
ESCC_QUALITY_GATE_STRICT=false

# Max live sends per session before the bulk guard in pre:outbound-send-gate
# trips. Integer.
ESCC_BULK_SEND_MAX=5

# Master switch for the fail-closed outbound send gate. Allowed: on | off.
# DANGEROUS ESCAPE HATCH: off disables pre:outbound-send-gate, removing the
# fail-closed protection that blocks un-reviewed live sends. Leave on in all
# normal operation; only set off for deliberate, supervised testing.
ESCC_OUTBOUND_GATE=on

# How long a per-recipient outbound approval token stays valid (v1.1.0).
# Integer minutes; default 10080 (7 days) for a human-paced review→send window.
# The gate also enforces drafts + HubSpot OUTBOUND email engagements (not just
# live sends): each needs an approval token written by the blessed path
# (email-outbound-ops / /escc-worklist). See rules/common/outbound-gates.md.
ESCC_OUTBOUND_APPROVAL_TTL_MINUTES=10080

# ─────────────────────────────────────────────────────────────────────────────
# Amendment A.6 — durable-context retention
# ─────────────────────────────────────────────────────────────────────────────

# Retention for account-memory entries (durable store beyond session summaries),
# in days. Blank = keep indefinitely.
ESCC_MEMORY_RETENTION_DAYS=

# Retention for instinct observations (the continuous-learning observe store),
# in days. Blank = keep indefinitely.
ESCC_OBSERVATION_RETENTION_DAYS=

# Cadence for the `escc watch` trigger sweep (overdue promises, imminent closes,
# etc.). Blank = default. Duration with suffix, e.g. 1h.
ESCC_WATCH_INTERVAL=
