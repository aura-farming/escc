# ESCC environment-variable surface (ESCC_*)
# Copy to .env; never commit real values. MCP API keys/tokens are configured in mcp-configs/, not here.
#
# All variables are optional: every one falls back to the default shown.
# ECC_* names/defaults are mirrored verbatim as ESCC_*. Booleans accept on/off
# and 1/0 (true/false) unless noted. Durations accept suffixes like 30s, 5m, 1h.

# ─────────────────────────────────────────────────────────────────────────────
# Hook dispatch & profile gating
# ─────────────────────────────────────────────────────────────────────────────

# Hook profile: which tier of hooks runs. Allowed: minimal | standard | strict.
ESCC_HOOK_PROFILE=standard

# Comma-separated hook ids to force-off regardless of profile.
# Ids use the pre:/post:/stop:/session: grammar.
# Example: pre:crm-write-guard,post:deliverables-location
ESCC_DISABLED_HOOKS=

# Max bytes of hook stdin to read before truncating. Oversized input fails OPEN
# (the action proceeds) and is recorded as hook_input_truncated when governance
# capture is enabled. Integer bytes.
ESCC_HOOK_INPUT_MAX_BYTES=1048576

# ─────────────────────────────────────────────────────────────────────────────
# Session persistence & SessionStart context injection
# ─────────────────────────────────────────────────────────────────────────────

# Char budget for the SessionStart context block (prior summary + open loops +
# high-confidence instincts), priority-budgeted by category. Integer chars.
ESCC_SESSION_START_MAX_CHARS=8000

# Toggle SessionStart context injection entirely. Allowed: on | off.
ESCC_SESSION_START_CONTEXT=on

# Data root for all ESCC state (session-data/, escc/state/, instincts, etc.).
# Path; ~ is expanded.
ESCC_AGENT_DATA_HOME=~/.claude

# ─────────────────────────────────────────────────────────────────────────────
# Observability, metrics & governance
# ─────────────────────────────────────────────────────────────────────────────

# Emit context-utilization / cost warnings from the context-monitor hook.
# Allowed: on | off.
ESCC_CONTEXT_MONITOR_COST_WARNINGS=on

# Capture audit events (secret_detected, policy_violation, approval_requested,
# hook_input_truncated, bulk_send_attempt, unapproved_send, crm_destructive_op).
# Off by default; set 1/on to enable. Allowed: on | off.
ESCC_GOVERNANCE_CAPTURE=off

# ─────────────────────────────────────────────────────────────────────────────
# MCP health & connectivity
# ─────────────────────────────────────────────────────────────────────────────

# If true, the mcp-health-check hook fails OPEN on a degraded/unreachable MCP
# (action proceeds). Default false = block on unhealthy MCP. Allowed: true | false.
ESCC_MCP_HEALTH_FAIL_OPEN=false

# Path to the MCP health state file used by mcp-health-check. Blank = default
# under ESCC_AGENT_DATA_HOME. Path.
ESCC_MCP_HEALTH_STATE_PATH=

# Path to the MCP servers config (the mcp-configs/ servers file). Blank = default.
# Path.
ESCC_MCP_CONFIG_PATH=

# Cached MCP health verdict lifetime before a re-probe. Integer ms.
ESCC_MCP_HEALTH_TTL_MS=120000

# Per-probe timeout for a stdio MCP health check. Integer ms.
ESCC_MCP_HEALTH_TIMEOUT_MS=5000

# Backoff window after an unhealthy verdict before the next live probe. Integer ms.
ESCC_MCP_HEALTH_BACKOFF_MS=30000

# Comma-separated MCP server names to skip (health checks and routing).
# Example: fireflies,hubspot
ESCC_DISABLED_MCPS=

# ─────────────────────────────────────────────────────────────────────────────
# Outbound send gate & quality gates
# ─────────────────────────────────────────────────────────────────────────────

# Strict mode for warn-only quality hooks (outbound-style-check, etc.):
# escalates warnings toward blocking. Allowed: true | false.
ESCC_QUALITY_GATE_STRICT=false

# Max live sends per session before the bulk guard in pre:outbound-send-gate
# trips. Integer.
ESCC_BULK_SEND_MAX=5

# Master switch for the fail-closed outbound send gate. Allowed: on | off.
# DANGEROUS ESCAPE HATCH: off disables pre:outbound-send-gate, removing the
# fail-closed protection that blocks un-reviewed live sends. Leave on in all
# normal operation; only set off for deliberate, supervised testing.
ESCC_OUTBOUND_GATE=on

# Require outbound OVERRIDES to be manager-signed (--approver-role) even
# outside the strict hook profile (which always requires it, v1.8.0
# separation of duties). Tighten-only. Allowed: 0 | 1.
ESCC_OVERRIDE_REQUIRES_MANAGER=0

# How long a per-recipient outbound approval token stays valid (v1.1.0).
# Integer minutes; default 10080 (7 days) for a human-paced review→send window.
# The gate also enforces drafts + HubSpot OUTBOUND email engagements (not just
# live sends): each needs an approval token written by the blessed path
# (email-outbound-ops / /escc-worklist). See rules/common/outbound-gates.md.
ESCC_OUTBOUND_APPROVAL_TTL_MINUTES=10080

# ─────────────────────────────────────────────────────────────────────────────
# Amendment A.6 — durable-context retention
# ─────────────────────────────────────────────────────────────────────────────

# Retention for account-memory entries (durable store beyond session summaries),
# in days. Blank = keep indefinitely.
ESCC_MEMORY_RETENTION_DAYS=

# Cadence for the `escc watch` trigger sweep (overdue promises, imminent closes,
# etc.). Blank = default. Duration with suffix, e.g. 1h.
ESCC_WATCH_INTERVAL=

# ─────────────────────────────────────────────────────────────────────────────
# Outbound gates & tools classification (advanced)
# ─────────────────────────────────────────────────────────────────────────────

# Minimum reviewer confidence an approval token / review marker must carry to
# satisfy the send gate. Float 0-1.
ESCC_OUTBOUND_REVIEW_MIN_CONFIDENCE=0.8

# Require an adversarial outbound-reviewer verdict (not just the four deterministic
# gates) before `escc outbound approve` mints a per-recipient token (ADR-0020).
# Default on = fail-closed: the sanctioned path cannot silently skip the reviewer.
# A logged --override still proceeds. Set off (0/false/no) ONLY for a deliberate,
# supervised fallback to the legacy four-gates-only approval. Allowed: on | off.
ESCC_OUTBOUND_REQUIRE_REVIEW=on

# Override path to the outbound tool-classification config. Blank = shipped
# config/outbound-tools.json (missing/unreadable falls back fail-closed).
ESCC_OUTBOUND_TOOLS_CONFIG=

# ─────────────────────────────────────────────────────────────────────────────
# Attachment quarantine
# ─────────────────────────────────────────────────────────────────────────────

# Set to 1 ONLY inside the read-only quarantine subagent context: it permits
# reading prospect-supplied files at quarantined paths. Never set globally.
ESCC_QUARANTINE_CONTEXT=0

# Extra directory to treat as quarantined (in addition to the built-in
# /inbound/, /attachments/ and mail-file patterns). Path; blank = none.
ESCC_QUARANTINE_DIR=

# ─────────────────────────────────────────────────────────────────────────────
# SessionStart hydration & compaction tuning
# ─────────────────────────────────────────────────────────────────────────────

# Force which account hydrates at session start. Blank = most recently
# touched account. Account id, e.g. domain:company.test.
ESCC_ACTIVE_ACCOUNT=

# Open loops older than this many days are flagged "stale — reverify" in the
# session digest and account truth view (never dropped). Integer days.
ESCC_LOOP_STALE_DAYS=21

# Window for "deal closing soon" alerts at session start. Integer days.
ESCC_IMMINENT_CLOSE_DAYS=14

# --- v1.9.0 digital twin ---
# Morning sweep: an account counts as "active" (and is reconciled) if it had an
# event within this many days. Unset = consider all accounts. Integer days.
ESCC_ACTIVE_ACCOUNT_WINDOW_DAYS=30

# Per-account voice overlay is refreshed when missing or older than this. The
# thread-reading skills check it against the overlay's "Last updated". Integer days.
ESCC_VOICE_STALE_DAYS=45

# Max knowledge candidates accepted per `escc product mine` call, so auto-mining
# every transcript cannot flood the operator review queue. Integer.
ESCC_MINE_MAX=25

# Window for the `escc twin` "what changed lately" digest. Integer days.
ESCC_TWIN_WINDOW_DAYS=7

# Minimum confidence an instinct needs to be injected at session start. Float 0-1.
ESCC_INSTINCT_CONFIDENCE=0.7

# How long a pre-compaction resume scratch stays resumable. Integer hours.
ESCC_COMPACTION_TTL_HOURS=24

# Tool-call count before the suggest-compact hook first nudges. Integer.
ESCC_COMPACT_THRESHOLD=50

# Retention for suggest-compact per-session state files. Integer days.
ESCC_COMPACT_STATE_TTL_DAYS=14

# ─────────────────────────────────────────────────────────────────────────────
# Rep identity, SLAs & notifications
# ─────────────────────────────────────────────────────────────────────────────

# Persona label shown in the statusline (sdr | ae | manager | revops). Blank = none.
ESCC_PERSONA=

# Rep identity for instinct-store attribution. Blank = derived. Free text/email.
ESCC_REP_IDENTITY=

# Role used by the instinct promotion gate (rep | manager). Both names accepted;
# ESCC_ROLE wins when both are set.
ESCC_ROLE=rep
ESCC_REP_ROLE=

# Sender email identity (instinct attribution + workspace defaults). Blank = unset.
ESCC_SENDER_EMAIL=

# HubSpot owner id/email used for owner-scoped defaults. Blank = unset.
ESCC_HUBSPOT_OWNER=

# Inbound response SLA used by the stop:sla-check hook. Integer hours.
ESCC_RESPONSE_SLA_HOURS=24

# Minimum user messages before evaluate-session records a learning signal. Integer.
ESCC_MIN_SESSION_LENGTH=10

# Set 1 to suppress desktop notifications from escc watch / notify. 0|1.
ESCC_NOTIFY_NO_DESKTOP=0

# Override path for the notify queue file. Blank = default under the data home.
ESCC_NOTIFY_QUEUE=

# ─────────────────────────────────────────────────────────────────────────────
# Knowledge layer & CI (advanced)
# ─────────────────────────────────────────────────────────────────────────────

# Days before volatile product-knowledge types (battlecards, pains) count as
# stale/unverified in retrieval. Integer days.
ESCC_KNOWLEDGE_VOLATILE_DAYS=60

# Root directory for the CI unicode-safety scan (CI use only). Blank = repo root.
ESCC_UNICODE_SCAN_ROOT=
