# Dependencies
node_modules/

# Secrets / local env
.env
.env.local
.env.*.local

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# Test / coverage output
coverage/
.nyc_output/

# Logs and scratch
*.log
*.tmp

# Local agent/session state (runtime, not source)
.pqa/

# Claude Code local overrides (never commit — machine-local settings/locks)
.claude/settings.local.json
.claude/*.lock

# ESCC runtime user-data — never commit to this public source repo (test data only).
# A private team workspace may instead choose to track battlecards/ and product/
# as shared knowledge, but should always keep accounts/ (prospect PII), state/, and
# sessions/ out of git — git history cannot be reached by `escc privacy-purge`.
# voice/ holds rep + per-account writing style mined from real correspondence;
# patterns/ and learned/pending instincts hold field-derived material. All of it
# is real company data and stays out of this public source. The shipped instinct
# seed under instincts/inherited/ is tracked deliberately and is NOT ignored.
.claude/escc/battlecards/
.claude/escc/product/
.claude/escc/accounts/
.claude/escc/state/
.claude/escc/sessions/
.claude/escc/voice/
.claude/escc/patterns/
.claude/escc/instincts/learned/
.claude/escc/instincts/pending/
